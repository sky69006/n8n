        "mode": "runOnceForEachItem",
        "jsCode": "// Access the current item\nconst item = $input.item;\nconst text = item.json.textHtml;\n\nfunction extractValue(label) {\n  const regex = new RegExp(label + \"[:]?\\\\s*(.*?)(<br|$)\", \"i\");\n  const match = text.match(regex);\n  return match ? match[1].trim() : null;\n}\n\nitem.json.subject = item.json.subject.replace(/^\\[SPAM ?\\] ?/, '')\n// Extract fields\nitem.json.naam = extractValue(\"Naam\");\nitem.json.email = extractValue(\"E-mailadres\");\nitem.json.telefoonnummer = extractValue(\"Telefoonnummer\");\nitem.json.adres = extractValue(\"Adres\");\nitem.json.functie = extractValue(\"functies\");\n//item.json.dbUrl = \"https://dataforge-basix18-staging-21422324.dev.odoo.com/\"\n//item.json.dbLogin = \"info@data-forge.be\"\n//item.json.dbPw = \"DataForgeTeam01\"\n//item.json.dbName = \"dataforge-basix18-staging-21422324\"\nitem.json.dbUrl = \"https://dataforge-basix18.odoo.com/\"\nitem.json.dbLogin = \"balder@basixafsluitingen.be\"\nitem.json.dbPw = \"4c2413fc9b79f701a08358ba1a2a8d5017f7735f\"\nitem.json.dbName = \"pivotal-dataforge-basix18-basix-15727765\"\n\n//item.json.dbUid = 6\nitem.json.dbUid = 2\nitem.json.messageId = $json.metadata['message-id']\n\n// Extract Bericht (everything after 'Bericht:')\nconst berichtMatch = text.match(/Bericht:([\\s\\S]*)/i);\nitem.json.bericht = berichtMatch ? berichtMatch[1]\n  .replace(/<br\\s*\\/?>/gi, \"\\n\")   // convert <br> to line breaks\n  .replace(/<\\/?[^>]+(>|$)/g, \"\")  // strip other HTML tags\n  .trim() : null;\n\nreturn item;\n"
