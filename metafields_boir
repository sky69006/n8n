        "pythonCode": "import xml.etree.ElementTree as ET\nimport json\n\ndef parse_odoo_xml(xml_data):\n    root = ET.fromstring(xml_data)\n    records = []\n\n    for struct in root.findall(\".//struct\"):\n        record = {}\n        for member in struct.findall(\"member\"):\n            name = member.find(\"name\").text\n            val_elem = member.find(\"value\")\n\n            if val_elem.find(\"string\") is not None:\n                value = val_elem.find(\"string\").text or \"\"\n            elif val_elem.find(\"int\") is not None:\n                value = int(val_elem.find(\"int\").text)\n            elif val_elem.find(\"double\") is not None:\n                value = float(val_elem.find(\"double\").text)\n            elif val_elem.find(\"boolean\") is not None:\n                value = val_elem.find(\"boolean\").text == \"1\"\n            elif val_elem.find(\"array\") is not None:\n                sub_vals = []\n                for item in val_elem.findall(\".//array/data/value\"):\n                    if item.find(\"int\") is not None:\n                        sub_vals.append(int(item.find(\"int\").text))\n                    elif item.find(\"string\") is not None:\n                        sub_vals.append(item.find(\"string\").text)\n                value = sub_vals\n            else:\n                value = None\n\n            record[name] = value\n        records.append(record)\n\n    return records\n\n# Main loop\nresults = []\nfor item in _input.all():\n    xml_string = item.json[\"data\"]\n    parsed = parse_odoo_xml(xml_string)\n    results.extend(parsed)\n\nreturn results"
