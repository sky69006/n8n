        "jsCode": "// Access the current item\nconst data = $json;\n\nlet partner = {\n  name: data.contact_name || data.name,\n  email: data.email_from,\n  phone: data.phone,\n  street: data.street,\n  zip: data.zip,\n  city: data.city,\n  is_company: false\n};\n\n// Remove keys with null, undefined, or empty string values\npartner = Object.fromEntries(\n  Object.entries(partner).filter(([_, v]) => v !== null && v !== undefined && v !== \"\")\n);\n\n// Return the transformed item\nreturn { json: partner };\n"
