        "pythonCode": "import json\n\nmetafields_list = []\n\nfor a in _input.all():\n    m = dict(a.json)\n  \n    raw_value = str(m['value'])  # Always convert to string\n\n    if \"list\" in m['type']:\n        # Convert comma-separated string to list of strings\n        list_items = [item.strip() for item in raw_value.split(\",\")]\n        sValue = json.dumps(json.dumps(list_items))  # ← double encode!\n    else:\n        sValue = json.dumps(raw_value)  # ← single encode for plain strings\n  \n    metafields_list.append(f\"\"\"\n    {{\n      namespace: \"{m['namespace']}\",\n      key: \"{m['key']}\",\n      type: \"{m['type']}\",\n      value: {sValue},\n      ownerId: \"{m['ownerId']}\"\n    }}\n    \"\"\")\n\n# Join all metafield definitions\nmetafields_str = \",\\n\".join(metafields_list)\n\n# Final GraphQL mutation string\nquery = f\"\"\"\nmutation {{\n  metafieldsSet(metafields: [\n    {metafields_str}\n  ]) {{\n    metafields {{\n      id\n      namespace\n      key\n      value\n      owner {{\n        ... on Product {{\n          id\n        }}\n      }}\n    }}\n    userErrors {{\n      field\n      message\n    }}\n  }}\n}}\n\"\"\"\n\n\n# Output the full GraphQL query\nreturn { \"query\": query }"
