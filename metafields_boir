        "language": "python",
        "pythonCode": "sOutput = []\n\n# Try fetching from MkNotFound module\ntry:\n    all_no_mk_node = _(\"MkNotFound\").all()\n    for item in all_no_mk_node:\n        itemDict = dict(item.json)\n        if 'success' in itemDict:\n            continue\n        sOutput.append({\n            'Status': 'error',\n            'Text': itemDict['default_code'] + ' heeft geen marketplace ID',\n            'IdOdoo': itemDict['id']\n        })\nexcept Exception:\n    # Node probably didn't execute; skip it\n    pass\n\nhasErrors = False\ntry:\n    all_insert_update_node = _(\"Splitsen in batches\").all()\n\n    for item in all_insert_update_node:\n      itemDict = dict(item.json)\n      print('Data:')\n      print(itemDict.get('data').get('metafieldsSet', {})\n            .get('userErrors', []))\n      errors = (\n        itemDict.get('data', {})\n            .get('metafieldsSet', {})\n            .get('userErrors', [])\n      )\n\n      if errors:\n        hasErrors = True\n        sOutput.append({\n            'Status': 'error',\n            'Text': '; '.join([e.get('message', '') for e in errors]),\n            'IdOdoo': itemDict.get('idOdoo', 'N/A')\n        })\nexcept Exception as e:\n    print(\"Error processing Insert/update uitvoeren:\", e)\n  \nif hasErrors == True:\n  return sOutput\n\n\n# Try fetching from Items met MK module\ntry:\n    other_nodes = _(\"Items met MK\").all()\n    for item in other_nodes:\n        itemDict = dict(item.json)\n\n        if itemDict.get('product_found') is True:\n            sOutput.append({\n                'Status': 'success',\n                'Text': itemDict['default_code'] + ' met success upgedate',\n                'IdOdoo': itemDict['odooId']\n            })\n\n        elif itemDict.get('product_found') is False:\n            sOutput.append({\n                'Status': 'error',\n                'Text': itemDict['default_code'] + ' heeft wel marketplace ID in Odoo maar deze ID ' + itemDict['mk_id'] + ' bestaat niet in Shopify',\n                'IdOdoo': itemDict['odooId']\n            })\nexcept Exception:\n    # Same here — if not executed, just skip\n    pass\n\nreturn sOutput"
      },
