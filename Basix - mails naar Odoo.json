    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Get the textHtml field safely\nconst html = $input.item.json.textHtml || '';\n\n// Return early if there's no HTML to parse\nif (!html || typeof html !== 'string') {\n  return [{ error: 'No textHtml provided or not a valid string' }];\n}\n\n// Helper to extract values from the HTML using label\nfunction extract(label) {\n  const regex = new RegExp(label + ':\\\\s*(.*?)<br>', 'i');\n  const match = html.match(regex);\n  return match ? match[1].trim() : null;\n}\n\n// Extract key fields from the email HTML\nconst name = extract('Naam');\nconst email = extract('e-mailadres');\nconst phone = extract('Telefoonnummer');\nconst street = extract('Straat');\nconst zip = extract('Postcode');\nconst message = extract('Bericht');\nconst street_number = extract('Straatnr');\n\n// Build raw lead object\nconst rawLead = {\n  name: name ? `Contact from ${name}` : null,\n  contact_name: name,\n  email_from: email,\n  phone: phone,\n  street: street + ', ' + street_number,\n  zip: zip,\n  description: message,\n  type: 'opportunity',\n  partner_name: name,\n  source_id: 10,\n  user_id: 10\n};\n\n// Clean the lead object: remove empty/null/undefined values\nconst lead = {};\nfor (const key in rawLead) {\n  if (rawLead[key] !== null && rawLead[key] !== undefined && rawLead[key] !== '') {\n    lead[key] = rawLead[key];\n  }\n}\n\n// Return the clean object\nreturn lead;\n"
      },
