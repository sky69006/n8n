    {
      "parameters": {
        "language": "python",
        "pythonCode": "all_odoo_data_node = _(\"Transformeren voor Shopify\").all()\nall_field_def_node = _(\"Metafields def\").all()\nall_metafields_data_node_graphql = _(\"Metafields ophalen 2\").all()\n\ndef extract_shopify_id(gid: str) -> str:\n    return gid.split('/')[-1]\n\ndef getCompVal(sInput):\n  if isinstance(sInput, float):\n    return str(sInput)\n  elif isinstance(sInput, int):\n    return str(float(sInput))\n  else:\n    return str(sInput)\n  return sInput\n\nallFieldDef = {}\nfor a in all_field_def_node:\n  aDict = dict(a.json)\n\n  for f in aDict['data']['metafieldDefinitions']['edges']:\n    allFieldDef[f['node']['key']] = f['node']\n\n#for a in allFieldDef.items():\n#  print(a)\n\nallMetasGraph = {}\n\nfor a in all_metafields_data_node_graphql:\n  aDict = dict(a.json)\n  #print(str(aDict))\n  if not aDict.get('data').get('product'):\n    continue\n    \n  productId = extract_shopify_id(aDict['data']['product']['id'])\n\n  for m in aDict['data']['product']['metafields']['edges']:\n    key = m['node'].get('key')\n\n    if productId and key:\n      if productId not in allMetasGraph.keys():\n        allMetasGraph[productId] = {}\n      else:\n        allMetasGraph[productId][key] = m['node']\n\n#for i in allMetasGraph.items():\n#  print(str(i))\n\nsOutput = []\n\n# Verwerk de Odoo data en koppel metafields\nfor a in all_odoo_data_node:\n    aDict = dict(a.json)\n    mk_id = str(aDict['mk_id'])\n    metafields = aDict.get('metafields', [])\n\n    # Voeg metafields van Shopify toe aan de Odoo-data\n    enriched_metafields = []\n    for m in metafields:\n      mdef = allFieldDef.get(m['metafield'])\n      #mdef = allFieldDef[m['metafield']]\n      #print('mdef:')\n      #print(mdef)\n\n      m['def'] = mdef\n      \n      metafield_key = m.get('metafield')\n\n      shopify_metafield_graph = allMetasGraph.get(mk_id, {}).get(metafield_key)\n      if shopify_metafield_graph:\n        m['shopifyValGraph'] = shopify_metafield_graph\n\n      targetType = None\n      if shopify_metafield_graph:\n        targetType = shopify_metafield_graph.get('type')\n      elif mdef:\n        targetType = mdef.get('type').get('name')\n      else:\n        targetType = m.get('shType')\n\n      m['targetType'] = targetType\n        \n      sValue = m.get('value')\n      sValue_str = str(sValue) if sValue is not None else ''\n\n      if shopify_metafield_graph == None:\n        m['isEmptyShop'] = True\n      else:\n        m['isEmptyShop'] = False\n        \n      m['compValShop'] = getCompVal(sValue)\n      \n      shopify_value_str = str(shopify_metafield_graph.get('value')) if shopify_metafield_graph and shopify_metafield_graph.get('value') is not None else ''\n\n      if m['isEmpty'] and m['isEmptyShop']:\n        sAction = 'Donothing'\n      elif m['isEmptyShop'] and not m['isEmpty']:\n        sAction = 'Insert'\n      elif not m['isEmptyShop'] and m['isEmpty']:\n        sAction = 'Delete'\n      elif m['compValShop'] == m['compValOdoo']:\n        sAction = 'Samevalue'\n      else:\n        sAction = 'Update'\n\n      m['action'] = sAction  \n\n    sOutput.append(aDict)\n\n# Resultaat retourneren\nreturn sOutput\n"
